# VolX local dev — copy to `.env` and adjust if needed.
# The `.env` file itself is gitignored.

# --- Storage --------------------------------------------------------
# Reached by the normalizer (#16) + engine (#20) + API (#23) crates.
# Local dev defaults match `docker/docker-compose.yml`.
CLICKHOUSE_URL=http://127.0.0.1:8123
CLICKHOUSE_DB=volx
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

REDIS_URL=redis://127.0.0.1:6379

# --- Tracing --------------------------------------------------------
# `tracing_subscriber::EnvFilter` syntax. Default is fine for normal
# work; override to `debug` / `trace` when chasing a specific module.
RUST_LOG=info,volx_ingestion=info,volx_normalizer=info

# --- Ingestion (#9, #10) --------------------------------------------
# Currently no env vars; future API-key auth lands here when #10's
# `.raw` channel work picks up.
