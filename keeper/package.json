{
  "name": "@volx/keeper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Off-chain oracle pusher: polls the VolX REST index and writes VolXOracle on deviation/heartbeat.",
  "scripts": {
    "start": "tsx src/index.ts",
    "once": "RUN_ONCE=1 tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/*.test.ts"
  },
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
