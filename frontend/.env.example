# Copy to .env.local for dev overrides.
#
# REST and WebSocket use different transport paths to reach the Go API:
#
#   API_PROXY_TARGET     – server-side. Next rewrites `/v1/*` to this URL.
#                          Used for REST. Default: http://localhost:8080
#
#   NEXT_PUBLIC_API_BASE – browser-side. Build-time embedded into the
#                          frontend bundle. Used only by the WebSocket
#                          client (rewrites cannot proxy the WS upgrade).
#                          Default: http://localhost:8080
#
# If the API is reachable on a non-default host, set BOTH to the same URL.

API_PROXY_TARGET=http://localhost:8080
NEXT_PUBLIC_API_BASE=http://localhost:8080
